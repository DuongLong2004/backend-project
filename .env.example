# SERVER
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000

# DATABASE
DB_HOST=localhost
DB_PORT=3306
DB_NAME=backend_db
DB_USER=root
DB_PASSWORD=your_password_here

# JWT
# Dùng giá trị ngẫu nhiên mạnh — chạy lệnh này để tạo:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m

# CORS / Frontend URL
# Dùng cho:
#   - CORS origin
#   - Email verify redirect: {CLIENT_URL}/verify-email-success
CLIENT_URL=http://localhost:5173

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# EMAIL (Nodemailer + Gmail SMTP)
# Hướng dẫn lấy App Password:
#   1. Bật 2-Step Verification: https://myaccount.google.com/signinoptions/twosv
#   2. Tạo App Password: https://myaccount.google.com/apppasswords
#   3. Copy 16 ký tự (KHÔNG dùng password Gmail thường!)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_FROM_NAME=Backend Project